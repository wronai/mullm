# Docker Compose — bez tego: `docker compose up -d` → „no service selected”
COMPOSE_PROFILES=core,web

# --- OpenRouter (RAG) ---
OPENROUTER_API_KEY=
# Lokalnie możesz użyć prefiksu openrouter/ — API normalizuje do deepseek/...
LLM_MODEL=deepseek/deepseek-v4-pro
EMBEDDING_MODEL=openai/text-embedding-3-small
RAG_AUTO_INGEST=true

# --- Postgres credentials ---
POSTGRES_DB=mullm
POSTGRES_USER=mullm
POSTGRES_PASSWORD=mullm_password

# --- Docker: service hostnames (internal DNS) ---
MULLM_POSTGRES_HOST=postgres
MULLM_NATS_HOST=nats
MULLM_REDIS_HOST=redis
MULLM_EVENTSTORE_HOST=eventstoredb
MULLM_ORCHESTRATOR_HOST=orchestrator
MULLM_PROJECTOR_HOST=projector

# --- Docker: container (internal) ports ---
MULLM_POSTGRES_PORT=5432
MULLM_NATS_CLIENT_PORT=4222
MULLM_NATS_MONITOR_PORT=8222
MULLM_REDIS_PORT=6379
MULLM_EVENTSTORE_PORT=2113
MULLM_ORCHESTRATOR_PORT=8000
MULLM_PROJECTOR_PORT=8000
MULLM_WEB_PORT=3000

# --- Host-published ports (localhost) ---
MULLM_POSTGRES_HOST_PORT=5433
MULLM_NATS_CLIENT_HOST_PORT=4222
MULLM_NATS_MONITOR_HOST_PORT=8222
MULLM_REDIS_HOST_PORT=6379
MULLM_EVENTSTORE_HOST_PORT=2113
MULLM_ORCHESTRATOR_HOST_PORT=8001
MULLM_PROJECTOR_HOST_PORT=8002
MULLM_WEB_HOST_PORT=3003

# --- URLs: from host / local dev ---
DATABASE_URL=postgresql://mullm:mullm_password@localhost:5433/mullm
NATS_URL=nats://localhost:4222
REDIS_URL=redis://localhost:6379
EVENTSTORE_URL=esdb://localhost:2113?tls=false
ORCHESTRATOR_URL=http://localhost:8001
PROJECTOR_URL=http://localhost:8002
WEB_URL=http://localhost:3003

# --- URLs: inside Docker network (used by compose services) ---
MULLM_DATABASE_URL=postgresql://mullm:mullm_password@postgres:5432/mullm
MULLM_NATS_URL=nats://nats:4222
MULLM_REDIS_URL=redis://redis:6379
MULLM_EVENTSTORE_URL=esdb://eventstoredb:2113?tls=false
MULLM_ORCHESTRATOR_URL=http://orchestrator:8000
MULLM_PROJECTOR_URL=http://projector:8000

# --- nlp2dsl (conversation loop — opcjonalnie) ---
# Uruchom: cd ../nlp2dsl && docker compose up -d
# lub: docker compose --profile nlp2dsl up -d (z katalogu mullm)
MULLM_NLP2DSL_BACKEND_HOST_PORT=8010
MULLM_NLP2DSL_NLP_HOST_PORT=8012
NLP2DSL_BACKEND_URL=http://localhost:8010
MULLM_NLP2DSL_BACKEND_URL=http://nlp2dsl-backend:8000

# --- nlp2cmd (NL → shell; Mullm tworzy ticket dla shell-agent) ---
# Uruchom: NLP2CMD=1 make up  lub  make nlp2cmd-up
MULLM_NLP2CMD_HOST_PORT=8020
NLP2CMD_BACKEND_URL=http://localhost:8020
MULLM_NLP2CMD_BACKEND_URL=http://nlp2cmd:8000

# --- Routing (inteligentny: nlp2cmd + opcjonalnie OpenRouter) ---
# auto = hybrid gdy nlp2cmd/OpenRouter dostępne; rules = tylko regex; llm = reguły+LLM
PROMPT_ROUTER_MODE=auto
MULLM_ROUTING_NLP2CMD=1
MULLM_ROUTING_NLP2CMD_MIN_CONFIDENCE=0.65
# Czekaj na stdout shell w tej samej odpowiedzi czatu (0 = tylko ticket, wynik w ◎)
MULLM_SHELL_WAIT_SECONDS=20
# Sync improvement_ticket (👎 routing) → planfile ticket create (wymaga planfile w PATH)
# MULLM_PLANFILE_PROJECT=/home/tom/github/wronai/mullm

# --- App ---
CATALOG_PATH=
ENVIRONMENT=development
EVENT_STORE_BACKEND=postgres
LOG_LEVEL=INFO
AGENT_ID=shell-agent-1
JWT_SECRET=your_jwt_secret_here
API_KEY=your_api_key_here
