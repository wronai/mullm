{
  "bundle_id": "mullm.routing.schemas.v1",
  "description": "Kontrakty HTTP Mullm ↔ nlp2cmd /query (mirror nlp2cmd.service Pydantic).",
  "request": {
    "type": "object",
    "required": ["query"],
    "properties": {
      "query": { "type": "string", "minLength": 1 },
      "dsl": { "type": "string", "default": "shell" },
      "explain": { "type": "boolean", "default": false },
      "execute": { "type": "boolean", "default": false }
    }
  },
  "response": {
    "type": "object",
    "required": ["success"],
    "properties": {
      "success": { "type": "boolean" },
      "command": { "type": "string" },
      "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
      "domain": { "type": "string" },
      "intent": { "type": "string" },
      "entities": { "type": "object" },
      "metadata": { "type": "object" },
      "explanation": { "type": "string" },
      "errors": { "type": "array" },
      "warnings": { "type": "array" }
    }
  }
}
